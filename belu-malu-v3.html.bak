<!-- lightbox -->
<div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="lbTitle">
  <div class="lb-back" data-lbclose></div>
  <div class="lb-panel">
    <button class="lb-close" id="lbClose" data-lbclose aria-label="Close detail view"><svg><use href="#i-close"/></svg></button>
    <figure class="lb-art"><div class="art" id="lbArt"></div></figure>
    <div class="lb-info">
      <span class="cat" id="lbCat"></span>
      <h3 id="lbTitle"></h3>
      <p class="med" id="lbMed"></p>
      <p class="avail" id="lbAvail"></p>
      <div class="brow">
        <a class="btn" href="#shop" data-v="shop">Shop prints <svg class="star"><use href="#i-star"/></svg></a>
        <a class="ghost" href="#connect" data-v="connect">Inquire</a>
      </div>
      <p class="lb-note">Image shown is a placeholder for Belu's real artwork.</p>
    </div>
  </div>
</div>

<script>
(function(){
  var reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  window.addEventListener('load',function(){document.body.classList.add('loaded')});
  setTimeout(function(){document.body.classList.add('loaded')},420);

  var mast=document.getElementById('mast'),fill=document.getElementById('threadFill'),needle=document.getElementById('threadNeedle'),topbar=document.getElementById('threadTop');
  function onScroll(){
    var y=window.scrollY||document.documentElement.scrollTop;
    mast.classList.toggle('small',y>30);
    var h=document.documentElement.scrollHeight-window.innerHeight;
    var p=h>0?Math.min(1,Math.max(0,y/h)):0;
    fill.style.height=(p*100)+'%';needle.style.top=(p*100)+'%';topbar.style.width=(p*100)+'%';
  }
  onScroll();window.addEventListener('scroll',onScroll,{passive:true});window.addEventListener('resize',onScroll);

  var io=null;
  if(!reduce&&'IntersectionObserver' in window){
    io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.12,rootMargin:'0px 0px -8% 0px'});
  }
  function reveal(view){view.querySelectorAll('[data-r]').forEach(function(n){if(reduce||!io){n.classList.add('in');return}n.classList.remove('in');io.observe(n)})}

  var views=document.querySelectorAll('.view');
  document.querySelectorAll('[data-v]').forEach(function(a){a.addEventListener('click',function(e){var id=a.getAttribute('data-v');if(!id)return;e.preventDefault();go(id)})});
  function go(id){
    var t=document.getElementById(id);
    if(!t||!t.classList.contains('view'))t=document.getElementById('home');
    views.forEach(function(v){v.classList.toggle('on',v===t)});
    document.querySelectorAll('.nav a[data-v]').forEach(function(a){var c=a.getAttribute('data-v')===t.id;if(c)a.setAttribute('aria-current','page');else a.removeAttribute('aria-current')});
    closeLB();closeMenu();window.scrollTo(0,0);reveal(t);onScroll();
    if(('#'+t.id)!==location.hash)history.replaceState(null,'','#'+t.id);
  }
  window.addEventListener('hashchange',function(){go(location.hash.replace('#','')||'home')});

  var menu=document.getElementById('menu');
  function openMenu(){menu.classList.add('open');menu.setAttribute('aria-hidden','false');document.getElementById('burger').setAttribute('aria-expanded','true');document.body.style.overflow='hidden'}
  function closeMenu(){menu.classList.remove('open');menu.setAttribute('aria-hidden','true');document.getElementById('burger').setAttribute('aria-expanded','false');document.body.style.overflow=''}
  document.getElementById('burger').addEventListener('click',openMenu);
  document.getElementById('burgerClose').addEventListener('click',closeMenu);

  /* lightbox */
  var lb=document.getElementById('lightbox'),lbArt=document.getElementById('lbArt'),lbCat=document.getElementById('lbCat'),lbTitle=document.getElementById('lbTitle'),lbMed=document.getElementById('lbMed'),lbAvail=document.getElementById('lbAvail'),lastFocus=null;
  function openLB(trig){
    var d=trig.dataset;lastFocus=trig;
    lbArt.className='art '+(d.art||'');lbCat.textContent=d.cat||'';lbTitle.textContent=d.title||'';lbMed.textContent=d.med||'';lbAvail.textContent=d.avail||'';
    lb.classList.add('open');lb.setAttribute('aria-hidden','false');document.body.style.overflow='hidden';document.getElementById('lbClose').focus();
  }
  function closeLB(){if(!lb.classList.contains('open'))return;lb.classList.remove('open');lb.setAttribute('aria-hidden','true');document.body.style.overflow='';if(lastFocus){lastFocus.focus();lastFocus=null}}
  window.bmCloseLB=closeLB;
  document.addEventListener('keydown',function(e){if(e.key==='Escape'){closeLB();closeMenu()}});

  /* toast + cart + filters + lightbox triggers (delegated) */
  var toast=document.getElementById('toast'),tmsg=document.getElementById('toastMsg'),tt;
  window.bmToast=function(m){tmsg.textContent=m;toast.classList.add('show');clearTimeout(tt);tt=setTimeout(function(){toast.classList.remove('show')},2600)};
  var cartN=document.getElementById('cartN'),cart=0;
  document.addEventListener('click',function(e){
    var close=e.target.closest('[data-lbclose]');if(close){e.preventDefault();closeLB();return}
    var lbt=e.target.closest('[data-lb]');if(lbt){e.preventDefault();openLB(lbt);return}
    var add=e.target.closest('[data-add]');
    if(add){e.preventDefault();cart++;cartN.textContent=cart;var ml=document.querySelector('.mast-cart');if(ml)ml.setAttribute('aria-label','Cart, '+cart+' items');bmToast((add.getAttribute('data-add')||'Item')+' added to cart');return}
    var chip=e.target.closest('[data-filter]');
    if(chip){
      var g=chip.closest('[data-fg]');if(!g)return;var f=chip.getAttribute('data-filter');
      g.querySelectorAll('[data-filter]').forEach(function(c){var on=c===chip;c.classList.toggle('on',on);c.setAttribute('aria-pressed',on?'true':'false')});
      var scope=document.getElementById(g.getAttribute('data-target'));
      if(scope)scope.querySelectorAll('[data-cat]').forEach(function(it){var cats=(it.getAttribute('data-cat')||'').split(' ');it.style.display=(f==='all'||cats.indexOf(f)>-1)?'':'none'});
    }
  });

  go(location.hash.replace('#','')||'home');
})();
</script>
</body>
</html>
