<!-- ============================ STYLE GUIDE (presentation only) ============================ -->
<section class="view" id="style">
  <div class="section">
    <div class="wrap">
      <div class="chap" data-r>
        <div class="ttl"><span class="kicker k">Design system</span><h2 style="font-size:clamp(2.4rem,5.5vw,3.8rem)">Style guide</h2></div>
      </div>
      <p class="lead" data-r style="margin-bottom:clamp(2rem,4vw,3rem)">The quiet system that holds it together: soft gallery white, charcoal, one living red thread, and her work doing the talking.</p>

      <div class="sg" data-r>
        <h3><span class="rl"></span>Colour</h3>
        <div class="sw-grid">
          <div class="sw"><div class="c" style="background:#f7f6f2"></div><div class="d"><b>Paper White</b><span>#F7F6F2</span></div></div>
          <div class="sw"><div class="c" style="background:#ecedea"></div><div class="d"><b>Gallery Gray</b><span>#ECEDEA</span></div></div>
          <div class="sw"><div class="c" style="background:#e4e1da"></div><div class="d"><b>Pale Stone</b><span>#E4E1DA</span></div></div>
          <div class="sw"><div class="c" style="background:#faf8f2"></div><div class="d"><b>Warm Surface</b><span>#FAF8F2</span></div></div>
          <div class="sw"><div class="c" style="background:#211e19"></div><div class="d"><b>Charcoal</b><span>#211E19</span></div></div>
          <div class="sw"><div class="c" style="background:#2c2924"></div><div class="d"><b>Soft Black</b><span>#2C2924</span></div></div>
          <div class="sw"><div class="c" style="background:#66625a"></div><div class="d"><b>Stone Text</b><span>#66625A</span></div></div>
          <div class="sw"><div class="c" style="background:#c63a2e"></div><div class="d"><b>Muted Red</b><span>#C63A2E</span></div></div>
          <div class="sw"><div class="c" style="background:#9e2d22"></div><div class="d"><b>Deep Red</b><span>#9E2D22</span></div></div>
          <div class="sw"><div class="c" style="background:#bc6b45"></div><div class="d"><b>Terracotta</b><span>#BC6B45</span></div></div>
          <div class="sw"><div class="c" style="background:#3c4f43"></div><div class="d"><b>Pine</b><span>#3C4F43</span></div></div>
          <div class="sw"><div class="c" style="background:#c29a45"></div><div class="d"><b>Ochre</b><span>#C29A45</span></div></div>
        </div>
        <p style="font-family:var(--read);color:var(--ink-2);margin-top:1.2rem;font-size:1rem">Airy gallery white with warmth underneath. Red is the thread, never a flood. Terracotta, pine, and ochre appear only as tiny accents pulled from the art.</p>
      </div>

      <div class="sg" data-r>
        <h3><span class="rl"></span>Typography</h3>
        <div class="trow">
          <div class="k">Display<br>Fraunces</div>
          <div><div style="font-family:var(--serif);font-size:clamp(2rem,4.4vw,3.2rem);line-height:1.03;font-variation-settings:'SOFT' 38,'opsz' 144">Movement, memory, and <em style="color:var(--red)">joy</em></div><div style="font-family:var(--grot);font-size:.7rem;letter-spacing:.06em;color:var(--stone);margin-top:.7rem">Soft optical serif · used large, with restraint</div></div>
        </div>
        <div class="trow">
          <div class="k">Reading<br>Newsreader</div>
          <div><p style="font-family:var(--read);font-size:1.2rem;line-height:1.72;margin:0;max-width:52ch">I returned to South America to travel, reconnect with my roots, and to save my wilting Spanish. The reading face carries the long-form journal voice.</p><div style="font-family:var(--grot);font-size:.7rem;letter-spacing:.06em;color:var(--stone);margin-top:.7rem">Literary serif · generous leading for essays</div></div>
        </div>
        <div class="trow">
          <div class="k">Interface<br>Archivo</div>
          <div><div style="display:flex;gap:1.4rem;flex-wrap:wrap;align-items:baseline"><span class="eyebrow"><svg class="star"><use href="#i-star"/></svg>Eyebrow label</span><span style="font-family:var(--grot);font-size:.76rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--stone)">Navigation</span><span style="font-family:var(--grot);font-size:.82rem;color:var(--ink)">$35 · pricing</span></div><div style="font-family:var(--grot);font-size:.7rem;letter-spacing:.06em;color:var(--stone);margin-top:.7rem">Crisp grotesque · labels, nav, captions</div></div>
        </div>
      </div>

      <div class="sg" data-r>
        <h3><span class="rl"></span>Buttons &amp; links</h3>
        <div class="brow">
          <span class="btn">Primary action <svg class="star"><use href="#i-star"/></svg></span>
          <span class="ghost">Secondary <svg style="width:22px;height:9px;fill:none;stroke:currentColor;stroke-width:1.6"><use href="#i-arrow"/></svg></span>
          <span class="link">Text link <svg class="ar" style="fill:none;stroke:currentColor;stroke-width:1.6"><use href="#i-arrow"/></svg></span>
          <span class="chip on" aria-hidden="true">Active filter</span>
          <span class="chip" aria-hidden="true">Filter</span>
        </div>
      </div>

      <div class="sg" data-r>
        <h3><span class="rl"></span>Image treatment &amp; motifs</h3>
        <div style="display:grid;grid-template-columns:280px 1fr;gap:2rem;align-items:start" class="motif-wrap">
          <div class="frame" style="max-width:280px"><div class="art art--neuroasis" style="aspect-ratio:4/5" role="img" aria-label="Framed artwork example (placeholder)"></div><div class="label"><span class="cat">Cat. 00 · Original</span><span class="t">Title, in italic</span><span class="m">Medium · size · year</span></div></div>
          <div class="mgrid">
            <div class="motif"><svg class="star" style="width:28px;height:28px;color:var(--red)"><use href="#i-star"/></svg><span class="lab">Logo star · waypoint</span></div>
            <div class="motif"><div style="height:40px;width:2px;background:var(--red);opacity:.55"></div><span class="lab">The thread · seam</span></div>
            <div class="motif"><svg viewBox="0 0 120 14" width="120" height="14" aria-hidden="true"><path d="M2 11C24 1 44 1 60 11S100 1 118 8" fill="none" stroke="var(--red)" stroke-width="1.6" stroke-linecap="round"/></svg><span class="lab">Route / wave line</span></div>
            <div class="motif"><svg viewBox="0 0 120 14" width="120" height="14" aria-hidden="true"><path d="M2 13L22 2L42 13M40 13L60 4L80 13M78 13L98 2L118 13" fill="none" stroke="var(--red)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg><span class="lab">Mountain linework</span></div>
          </div>
        </div>
        <p style="font-family:var(--grot);font-size:.66rem;letter-spacing:.04em;color:var(--stone);margin-top:1.2rem">Note: artwork shown throughout is a temporary placeholder. The finished build is designed around Belu's real pieces, with real portraits and the original logo asset.</p>
      </div>

      <div class="sg" data-r>
        <h3><span class="rl"></span>Spacing rhythm</h3>
        <div class="brow" style="align-items:flex-end;gap:1.4rem">
          <div style="text-align:center"><div style="background:var(--red);opacity:.85;width:46px;height:12px"></div><div style="font-family:var(--grot);font-size:.62rem;color:var(--stone);margin-top:.4rem">8</div></div>
          <div style="text-align:center"><div style="background:var(--red);opacity:.85;width:46px;height:20px"></div><div style="font-family:var(--grot);font-size:.62rem;color:var(--stone);margin-top:.4rem">16</div></div>
          <div style="text-align:center"><div style="background:var(--red);opacity:.85;width:46px;height:36px"></div><div style="font-family:var(--grot);font-size:.62rem;color:var(--stone);margin-top:.4rem">32</div></div>
          <div style="text-align:center"><div style="background:var(--red);opacity:.85;width:46px;height:60px"></div><div style="font-family:var(--grot);font-size:.62rem;color:var(--stone);margin-top:.4rem">64</div></div>
          <div style="text-align:center"><div style="background:var(--red);opacity:.85;width:46px;height:96px"></div><div style="font-family:var(--grot);font-size:.62rem;color:var(--stone);margin-top:.4rem">120</div></div>
        </div>
        <p style="font-family:var(--read);color:var(--ink-2);margin-top:1.2rem;font-size:1rem">Sections breathe at 120px and up. Negative space is part of the design, not leftover room.</p>
      </div>
    </div>
  </div>
</section>
</main>

